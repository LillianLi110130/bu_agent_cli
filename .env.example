# API Keys
OPENAI_API_KEY=your-openai-api-key-here
ZHIPU_API_KEY=your-zhipu-api-key-here

# Model Configuration
LLM_MODEL=GLM-4.7
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# TG Memory Integration
TG_MEM_ENABLED=true
TG_MEM_MYSQL_DB_URI=mysql://mem0:your-password@127.0.0.1:3306/mem0
TG_MEM_LLM_MODEL=GLM-4.7
TG_MEM_OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
TG_MEM_OPENAI_API_KEY=your-openai-api-key-here
TG_MEM_MAX_MEMORY_CONTEXT_CHARS=20000

# Telegram Gateway
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOW_FROM=123456789,987654321
TELEGRAM_PROXY=

# Zhaohu Webhook Gateway
ZHAOHU_ENABLED=false
ZHAOHU_HOST=0.0.0.0
ZHAOHU_PORT=18080
ZHAOHU_WEBHOOK_PATH=/webhook/zhaohu

# Gateway Heartbeat
GATEWAY_HEARTBEAT_ENABLED=true
GATEWAY_HEARTBEAT_INTERVAL_SECONDS=1800
