<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.buagent.gateway.store.mapper.OnlineWorkerMapper">

    <resultMap id="OnlineWorkerResultMap" type="com.buagent.gateway.store.entity.OnlineWorkerEntity">
        <id property="workerId" column="worker_id"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findByWorkerId" resultMap="OnlineWorkerResultMap">
        SELECT worker_id, status, create_time, update_time
        FROM online_worker
        WHERE worker_id = #{workerId}
    </select>

    <insert id="insert" parameterType="com.buagent.gateway.store.entity.OnlineWorkerEntity">
        INSERT INTO online_worker (
            worker_id,
            status
        ) VALUES (
            #{workerId},
            #{status}
        )
    </insert>

    <update id="updateStatus">
        UPDATE online_worker
        SET status = #{status},
            update_time = CURRENT_TIMESTAMP
        WHERE worker_id = #{workerId}
    </update>
</mapper>
